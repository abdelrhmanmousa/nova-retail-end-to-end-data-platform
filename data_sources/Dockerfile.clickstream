FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY clickstream_producer.py .

# Reads GCP_PROJECT_ID, PUBSUB_TOPIC from the environment.
# Runs forever, so this is meant for Cloud Run (as a Service, not a Job) or a
# small GCE/GKE workload — not a one-shot Cloud Run Job like the seed script.
ENTRYPOINT ["python", "clickstream_producer.py"]
