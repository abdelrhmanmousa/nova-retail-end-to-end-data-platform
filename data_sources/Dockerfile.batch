FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY supplier_catalog_generator.py currency_rates_fetcher.py ./

# No ENTRYPOINT - Composer's KubernetesPodOperator specifies which script to
# run via cmds/arguments, so this one image serves both batch producers.
